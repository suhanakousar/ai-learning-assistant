# =============================================================================
# AI Learning Assistant - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider (choose one)
# -----------------------------------------------------------------------------
# Options: openai | openrouter | ollama | grok
LLM_PROVIDER=grok

# -----------------------------------------------------------------------------
# OpenAI (when LLM_PROVIDER=openai)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: use a specific model
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# OpenRouter (when LLM_PROVIDER=openrouter)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# Ollama (when LLM_PROVIDER=ollama)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Grok / xAI (when LLM_PROVIDER=grok)
# -----------------------------------------------------------------------------
GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-4-fast-reasoning

# -----------------------------------------------------------------------------
# Google Gemini (when LLM_PROVIDER=gemini)
# Keys from https://aistudio.google.com/app/apikey often start with gsk_
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-ai-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Embeddings (for Document QA - FAISS)
# -----------------------------------------------------------------------------
# Use: openai | google (uses GOOGLE_API_KEY) | ollama
EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
GOOGLE_EMBEDDINGS_MODEL=models/gemini-embedding-001

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# Document QA: chunk size and overlap for text splitting
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=200
